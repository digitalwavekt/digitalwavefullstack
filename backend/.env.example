# Backend .env example - copy to .env and fill values for local testing
# Database
# Set DB_TYPE to one of: mongodb, postgres, supabase, memory
DB_TYPE=memory
# For MongoDB
MONGODB_URI=
# For Postgres
POSTGRES_URL=
# For Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# App
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=

# Auth
JWT_SECRET=please_change_me_for_prod

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AUTO_GENERATE_AI=false

# Payment (example keys - do NOT commit real keys)
PAYMENT_PROVIDER=payu
PAYU_KEY=
PAYU_SALT=

# Email (for nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Logging
JSON_LIMIT=10mb
URLENCODED_LIMIT=10mb
